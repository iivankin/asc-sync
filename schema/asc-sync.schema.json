{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orbitstorage.dev/schemas/asc-sync.schema-0.1.0.json",
  "title": "asc-sync config",
  "type": "object",
  "additionalProperties": false,
  "required": ["teamId"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Version-pinned published schema URL from https://orbitstorage.dev/schemas/."
    },
    "teamId": {
      "type": "string",
      "minLength": 1
    },
    "bundleIds": {
      "type": "object",
      "default": {},
      "propertyNames": {
        "$ref": "#/$defs/nonEmptyKey"
      },
      "additionalProperties": {
        "$ref": "#/$defs/bundleId"
      }
    },
    "devices": {
      "type": "object",
      "default": {},
      "propertyNames": {
        "$ref": "#/$defs/nonEmptyKey"
      },
      "additionalProperties": {
        "$ref": "#/$defs/device"
      }
    },
    "certs": {
      "type": "object",
      "default": {},
      "propertyNames": {
        "$ref": "#/$defs/nonEmptyKey"
      },
      "additionalProperties": {
        "$ref": "#/$defs/cert"
      }
    },
    "profiles": {
      "type": "object",
      "default": {},
      "propertyNames": {
        "$ref": "#/$defs/nonEmptyKey"
      },
      "additionalProperties": {
        "$ref": "#/$defs/profile"
      }
    }
  },
  "$defs": {
    "nonEmptyKey": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!(?:\\.|\\.\\.)$)[A-Za-z0-9._-]+$"
    },
    "bundleId": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundleId", "name", "platform"],
      "properties": {
        "bundleId": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "enum": ["ios", "mac_os", "universal"]
        },
        "capabilities": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/capability"
          }
        }
      }
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "udid", "name"],
      "properties": {
        "family": {
          "type": "string",
          "enum": ["ios", "ipados", "watchos", "tvos", "visionos", "macos"]
        },
        "udid": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "cert": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "development",
            "distribution",
            "developer_id_application"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "bundleId", "certs"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "ios_app_development",
            "ios_app_store",
            "ios_app_adhoc",
            "ios_app_inhouse",
            "tvos_app_development",
            "tvos_app_store",
            "tvos_app_adhoc",
            "tvos_app_inhouse",
            "mac_app_development",
            "mac_app_store",
            "mac_app_direct",
            "mac_catalyst_app_development",
            "mac_catalyst_app_store",
            "mac_catalyst_app_direct"
          ]
        },
        "bundleId": {
          "type": "string",
          "minLength": 1
        },
        "certs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "devices": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "capability": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "in_app_purchase",
            "game_center",
            "push_notifications",
            "wallet",
            "inter_app_audio",
            "maps",
            "associated_domains",
            "personal_vpn",
            "app_groups",
            "healthkit",
            "homekit",
            "wireless_accessory_configuration",
            "apple_pay",
            "sirikit",
            "network_extensions",
            "multipath",
            "hot_spot",
            "nfc_tag_reading",
            "classkit",
            "autofill_credential_provider",
            "access_wifi_information",
            "network_custom_protocol",
            "coremedia_hls_low_latency",
            "system_extension_install",
            "user_management"
          ]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["icloud"],
          "properties": {
            "icloud": {
              "type": "object",
              "additionalProperties": false,
              "required": ["version"],
              "properties": {
                "version": {
                  "type": "string",
                  "enum": ["xcode_5", "xcode_6"]
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["data_protection"],
          "properties": {
            "data_protection": {
              "type": "object",
              "additionalProperties": false,
              "required": ["level"],
              "properties": {
                "level": {
                  "type": "string",
                  "enum": [
                    "complete_protection",
                    "protected_unless_open",
                    "protected_until_first_user_auth"
                  ]
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["apple_id_auth"],
          "properties": {
            "apple_id_auth": {
              "type": "object",
              "additionalProperties": false,
              "required": ["appConsent"],
              "properties": {
                "appConsent": {
                  "type": "string",
                  "enum": ["primary_app_consent"]
                }
              }
            }
          }
        }
      ]
    }
  }
}
